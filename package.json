{
	"name": "recalbox-dashboard-monorepo",
	"private": true,
	"version": "1.0.1",
	"packageManager": "pnpm@10.26.2",
	"scripts": {
		"dev": "pnpm --filter @recalbox/dashboard dev",
		"dev:all": "pnpm --filter @recalbox/dashboard dev:all",
		"dev:all:mobile": "pnpm --filter @recalbox/dashboard dev:all:mobile",
		"build": "pnpm -r build",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "pnpm -r test",
		"scrobbler:dev": "pnpm --filter @recalbox/dashboard scrobbler:dev",
		"seed:dev": "pnpm --filter @recalbox/dashboard seed:dev",
		"seed:clear": "pnpm --filter @recalbox/dashboard seed:clear",
		"gamelist:import": "pnpm --filter @recalbox/dashboard gamelist:import",
		"gamelist:clear": "pnpm --filter @recalbox/dashboard gamelist:clear"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"react-doctor": "^0.2.14",
		"typescript": "^5.6.0"
	},
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=9.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["better-sqlite3", "esbuild", "ssh2"]
	}
}
