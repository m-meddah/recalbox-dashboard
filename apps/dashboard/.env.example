# Recalbox connection
RECALBOX_HOST=recalbox.local
RECALBOX_SSH_USER=root
RECALBOX_SSH_PASSWORD=recalboxroot

# MQTT broker (running on Recalbox)
MQTT_BROKER_URL=mqtt://recalbox.local:1883
MQTT_TOPIC_PREFIX=recalbox

# SMB / network share for gamelists
GAMELIST_BASE_PATH=/mnt/recalbox/share/roms

# Database
DATABASE_PATH=./recalbox.db

# App
NEXT_PUBLIC_APP_NAME=Recalbox Dashboard

# Auth (Better Auth) — generate a 32+ char secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated origins Better Auth accepts (CSRF / cross-origin). For a public
# Tailscale Funnel deployment, set this to the public URL, e.g.
# https://<node>.<tailnet>.ts.net (add any MagicDNS name too). Defaults to
# BETTER_AUTH_URL when unset.
BETTER_AUTH_TRUSTED_ORIGINS=

# Credential encryption (SSH/IGDB secrets at rest).
# Optional: defaults to deriving a key from BETTER_AUTH_SECRET.
# Set only to rotate the credential key independently of the auth secret.
CREDENTIALS_SECRET=
