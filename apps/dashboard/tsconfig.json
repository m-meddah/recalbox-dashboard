{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "preserve",
		"allowJs": true,
		"incremental": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"plugins": [{ "name": "next" }],
		"paths": { "@/*": ["./*"] }
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
