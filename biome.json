{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"files": {
		"ignore": ["node_modules", ".next", "dist", "build", "*.min.js"]
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "all"
		}
	},
	"linter": { "rules": { "recommended": true } },
	"overrides": [
		{
			"include": ["**/progress-bar.tsx"],
			"linter": {
				"rules": {
					"suspicious": { "noArrayIndexKey": "off" }
				}
			}
		},
		{
			"include": ["**/play-tonight/recommendation-card.tsx"],
			"linter": {
				"rules": {
					"suspicious": { "noExplicitAny": "off" }
				}
			}
		}
	]
}
